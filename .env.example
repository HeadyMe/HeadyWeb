# HeadyWeb Environment Variables
# Copy this to .env and fill in your values

# Firebase (optional — runs in demo mode without these)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=headyweb.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=headyweb
VITE_FIREBASE_STORAGE_BUCKET=headyweb.appspot.com
VITE_FIREBASE_MESSAGING_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Turnstile (optional — bot protection disabled without this)
VITE_TURNSTILE_SITEKEY=
